    "build:dev": "npm run build:wasm:dev && npm run build:web:dev",
    "build:prod": "npm run build:wasm:prod && npm run build:web:prod",
    "serve": "python3 -m http.server --dir ./build"
  },
  "dependencies": {
    "@babel/preset-env": "^7.29.0",
