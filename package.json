    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "d3": "^7.9.0",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.1",
    "quantum": "file:./rust/pkg",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "safe-expr-eval": "^1.0.0",
    "style-loader": "^4.0.0",
    "use-force-update": "^2.0.0",
    "webpack": "^5.105.4"
  },
  "devDependencies": {
    "webpack-cli": "^6.0.1"
  }
